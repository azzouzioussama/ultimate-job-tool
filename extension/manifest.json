{
  "manifest_version": 3,
  "name": "Ultimate Job Tool Companion",
  "version": "1.0.0",
  "description": "Companion extension for the Ultimate Job Hunting Tool. Automates cover letter insertion, CV syncing, and form autofilling on ATS boards.",
  "permissions": [
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.vercel.app/*",
    "*://*.greenhouse.io/*",
    "*://*.lever.co/*",
    "*://*.ashbyhq.com/*",
    "*://*.smartrecruiters.com/*",
    "*://*.indeed.com/*",
    "*://*.indeed.fr/*",
    "*://*.hellowork.com/*",
    "*://*.welcometothejungle.com/*",
    "*://*.freework.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.vercel.app/*",
        "https://ultimate-job-tool.vercel.app/*"
      ],
      "js": ["content_app.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*.greenhouse.io/*",
        "*://*.lever.co/*",
        "*://*.ashbyhq.com/*",
        "*://*.smartrecruiters.com/*",
        "*://*.indeed.com/*",
        "*://*.indeed.fr/*",
        "*://*.myworkdayjobs.com/*",
        "*://*.hellowork.com/*",
        "*://*.welcometothejungle.com/*",
        "*://*.freework.com/*",
        "*://*.workable.com/*"
      ],
      "js": [
        "autofill_engine.js",
        "adapters/generic.js",
        "adapters/greenhouse.js",
        "adapters/lever.js",
        "adapters/ashby.js",
        "adapters/smartrecruiters.js",
        "adapters/indeed.js",
        "adapters/hellowork.js",
        "adapters/welcometothejungle.js",
        "adapters/freework.js",
        "content_filler.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
